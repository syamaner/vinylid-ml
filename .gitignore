.pytest_cache/

# PyTorch
*.pt
*.pth
*.onnx

# --- Privacy & large files (never commit) ---

# Real-world test photos (may contain faces, GPS)
test_photos/

# Experiment outputs (uploaded to HF Hub, not git)
# Large binary artifacts inside results/ — use HF Hub for these
results/**/*.pt
results/**/*.pth
results/**/*.npy
results/**/*.npz
results/**/*.safetensors
results/**/*.bin
results/**/embeddings/
# Everything else in results/ (metrics.json, config.json, CSVs, HTMLs) is tracked

# CoreML models and indexes (uploaded to HF Hub, not git)
coreml/

# Embedding caches
*.npy
*.npz
gallery.idx

# Dataset artifacts (generated locally by prepare_dataset.py)
data/manifest.parquet
data/manifest_errors.csv
data/splits.json
data/test_*_matched.csv
data/augmented/
# Model embeddings (go to HF Hub, not git)
data/*/embeddings.npy
data/*/metadata.json

# Progress tracking (local only)
PROGRESS.md

# Claude Code (local-only files)
CLAUDE.local.md
.claude/settings.local.json

# HF Hub cache
.cache/
